# Safety (required)
DRY_RUN=true
DISPATCH_PHASE=1

# Mode: true = use fixtures only, no API/DB
MOCK_MODE=true

# Test API — order detail (POST JSON body: {"id": <numeric_id>})
API_BASE_URL=http://192.168.2.223:18080
API_TOKEN=
API_ORDER_PATH=/app-api/order/publish-order/get
API_TENANT_HEADER=tenant-id
API_TIMEOUT_SEC=10

# customer_type: data.tenantId == HX_TENANT_ID → 汇信昌，否则 非汇信昌
HX_TENANT_ID=1

# Read-only MySQL — candidate pool (same as MCP: hxc_cloud)
DB_HOST=
DB_PORT=3306
DB_NAME=hxc_cloud
DB_USER=
DB_PASSWORD=

# LLM (OpenAI-compatible)
LLM_BASE_URL=https://llm-tgefxsufbpuip2bt.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SEC=30
# true = fall back to rule-based agent when LLM call fails
LLM_FALLBACK=true

# Demo — TEST_ORDER_NO is order_no (DD...); ApiClient resolves numeric id before API call
TEST_ORDER_NO=DD20260702000005
TEST_ORDER_ID=
MAX_STEPS=8
T_SESSION_SEC=30

# SQLite audit
SQLITE_PATH=./data/demo.db
